<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">
<meta
  name="viewport"
  content="width=device-width, initial-scale=1"
/>

<title>Scanner RDC</title>

<script src="https://unpkg.com/html5-qrcode"></script>

<style>

body{
  background:#111;
  color:white;
  font-family:Arial;
  margin:0;
  padding:20px;
  text-align:center;
}

.logo{
  width:120px;
  border-radius:50%;
  margin-top:10px;
}

h1{
  color:#e30613;
}

#reader{
  width:100%;
  max-width:500px;
  margin:auto;
  border-radius:20px;
  overflow:hidden;
  background:#1c1c1c;
}

#resultado{
  margin-top:20px;
  background:#1c1c1c;
  border-radius:15px;
  padding:20px;
  font-size:22px;
  font-weight:bold;
}

button{
  margin-top:20px;
  border:none;
  background:#e30613;
  color:white;
  padding:18px 30px;
  border-radius:15px;
  font-size:20px;
  font-weight:bold;
  cursor:pointer;
}

</style>

</head>

<body>

<img
  class="logo"
  src="https://raw.githubusercontent.com/Greina00/rdc-media/main/logo3.png"
>

<h1>
🏍️ Scanner RDC
</h1>

<div id="reader"></div>

<button onclick="iniciarScanner()">
📷 ACTIVAR CÁMARA
</button>

<div id="resultado">
Esperando inicio...
</div>

<script>

const WEBAPP =
'https://script.google.com/macros/s/TU_URL_WEBAPP/exec';

let scanner;

async function iniciarScanner(){

  const resultado =
    document.getElementById(
      'resultado'
    );

  try{

    scanner =
      new Html5Qrcode(
        "reader"
      );

    await scanner.start(
      {
        facingMode:
        "environment"
      },
      {
        fps:10,
        qrbox:250
      },
      function(decodedText){

        procesarQR(
          decodedText
        );

      }
    );

    resultado.innerHTML =
      '📷 Cámara lista';

  }catch(err){

    resultado.innerHTML =
      '❌ Error activando cámara';
  }

}

async function procesarQR(decodedText){

  const resultado =
    document.getElementById(
      'resultado'
    );

  try{

    const url =
      new URL(
        decodedText
      );

    const token =
      url.searchParams.get(
        'token'
      );

    if(!token){

      resultado.innerHTML =
        '❌ QR inválido';

      return;
    }

    resultado.innerHTML =
      '⏳ Procesando...';

    const response =
      await fetch(
        WEBAPP
        + '?checkin=1'
        + '&token='
        + token
      );

    const text =
      await response.text();

    resultado.innerHTML =
      '✅ CHECK-IN REALIZADO';

  }catch(err){

    resultado.innerHTML =
      '❌ QR inválido';
  }

}

</script>

</body>
</html>
